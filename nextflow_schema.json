{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "openSesame parameters",
  "type": "object",
  "properties": {
    "input": {"type":"string","description":"CSV samplesheet with sample_id,idat_red,idat_green."},
    "input_glob": {"type":"string","description":"Deprecated IDAT glob; internally converted to a samplesheet."},
    "outdir": {"type":"string","default":"results","description":"Output directory."},
    "platform": {"type":"string","enum":["EPICv2"],"default":"EPICv2","description":"Requested verified array platform."},
    "sesame_prep_code": {"type":"string","pattern":"^[QCDPBHT]+$","default":"QCDPB","description":"Explicit SeSAMe prepSesame code."},
    "min_detection_rate": {"type":"number","minimum":0,"maximum":1,"default":0.95,"description":"Minimum per-probe/sample call rate."},
    "max_missing_rate": {"type":"number","minimum":0,"maximum":1,"default":0.05,"description":"Maximum beta missingness per probe."},
    "auto_exclude_samples": {"type":"boolean","default":false,"description":"Apply rather than only propose QC exclusions."},
    "find_dmps": {"type":"boolean","default":false,"description":"Run limma DMP analysis on M-values."},
    "find_dmrs": {"type":"boolean","default":false,"description":"Run DMRcate using the same DMP design and contrast."},
    "design": {"type":"string","default":"~ 0 + group","description":"R model formula using samplesheet columns."},
    "contrast": {"type":"string","description":"Comma-separated limma/DMRcate contrasts, e.g. groupDisease-groupControl."},
    "fdr": {"type":"number","minimum":0,"maximum":1,"default":0.05,"description":"DMP Benjamini-Hochberg threshold."},
    "min_abs_delta_beta": {"type":"number","minimum":0,"maximum":1,"default":0.05,"description":"Minimum absolute DMP/DMR delta beta."},
    "dmr_bandwidth": {"type":"number","exclusiveMinimum":0,"default":1000,"description":"DMRcate smoothing bandwidth (lambda, bp)."},
    "dmr_scaling": {"type":"number","exclusiveMinimum":0,"default":2,"description":"DMRcate scaling factor (C)."},
    "dmr_min_probes": {"type":"integer","minimum":2,"default":3,"description":"Minimum CpGs required in a reported DMR."},
    "dmr_fdr": {"type":"number","minimum":0,"maximum":1,"default":0.05,"description":"Maximum smoothed DMR FDR."},
    "dmr_epicv2_filter": {"type":"string","enum":["mean","sensitivity","precision","random"],"default":"mean","description":"DMRcate EPICv2 replicate-probe handling."},
    "dmr_epicv2_remap": {"type":"boolean","default":true,"description":"Use DMRcate documented EPICv2 off-target remapping."},
    "run_cell_composition": {"type":"boolean","default":false,"description":"Reserved for a validated user reference workflow; disabled by default."},
    "cell_reference": {"type":"string","description":"User-supplied validated reference matrix/object."},
    "batch_correction": {"type":"string","enum":["none"],"default":"none","description":"Known batches should be included in --design; correction is not yet enabled."}
  },
  "allOf":[{"not":{"required":["input","input_glob"]}}]
}
