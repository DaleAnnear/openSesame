process {
    container = 'docker.io/daleannear/opensesame:0.2.0'
    shell = ['/bin/bash', '-euo', 'pipefail']
    errorStrategy = { task.exitStatus in [137, 143] ? 'retry' : 'terminate' }
    maxRetries = 2
    withLabel: process_low { cpus = 1; memory = 4.GB; time = 2.h }
    withLabel: process_medium { cpus = 2; memory = 12.GB; time = 8.h }
    withLabel: process_high { cpus = 4; memory = 32.GB; time = 24.h }
    withLabel: process_ultra { cpus = 8; memory = 64.GB; time = 48.h }
}
timeline.enabled = true
timeline.file = "${params.outdir}/pipeline_info/execution_timeline.html"
report.enabled = true
report.file = "${params.outdir}/pipeline_info/execution_report.html"
trace.enabled = true
trace.file = "${params.outdir}/pipeline_info/execution_trace.txt"
dag.enabled = true
dag.file = "${params.outdir}/pipeline_info/pipeline_dag.html"
