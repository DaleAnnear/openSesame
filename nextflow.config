manifest {
    name = 'DaleAnnear/openSesame'
    description = 'EPICv2-oriented Illumina methylation-array analysis with SeSAMe'
    mainScript = 'main.nf'
    version = '0.2.0-dev'
    nextflowVersion = '>=26.04.4'
}
params {
    input = null
    input_glob = null
    outdir = 'results'
    platform = 'EPICv2'
    allow_mixed_arrays = false
    genome_build = 'hg38'
    preprocess_method = 'openSesame'
    sesame_prep_code = 'QCDPB'
    min_detection_rate = 0.95
    max_missing_rate = 0.05
    remove_sex_chromosomes = false
    remove_non_cpg = false
    probe_exclusion_list = null
    auto_exclude_samples = false
    find_dmps = false
    find_dmrs = false
    design = '~ 0 + group'
    contrast = null
    fdr = 0.05
    min_abs_delta_beta = 0.05
    dmr_bandwidth = 1000
    dmr_scaling = 2
    dmr_min_probes = 3
    cell_reference = null
    run_cell_composition = false
    batch_correction = 'none'
    publish_mode = 'copy'
}
includeConfig 'conf/base.config'
profiles {
    docker { includeConfig 'conf/docker.config' }
    apptainer { includeConfig 'conf/apptainer.config' }
    singularity { includeConfig 'conf/apptainer.config' }
    slurm { includeConfig 'conf/slurm.config' }
    test { includeConfig 'conf/test.config' }
}
